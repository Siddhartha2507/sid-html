* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Poppins', sans-serif;
}
body {
    background: linear-gradient(135deg, #eef2ff, #e0f7fa);
    padding: 25px;
    color: #333;
}
header {
    display: flex;
    align-items: center;
    gap: 25px;
    margin-bottom: 20px;
}

.dp {
    width: 130px;
    height: 130px;
    border-radius: 50%;
    border: 5px solid #161e02;
}

h1 {
    color: #19191e;
}

.tag {
    font-weight: 400;
}

.sub {
    font-size: 14px;
    color: gray;
}

nav {
    background: #17162e;
    padding: 10px;
    border-radius: 10px;
    text-align: center;
    margin-bottom: 20px;
}

nav a {
    color: white;
    text-decoration: none;
    margin: 0 12px;
    font-size: 14px;
}

nav a:hover {
    text-decoration: underline;
}   
.card {
    background: white;
    padding: 18px;
    margin: 15px 0;
    border-radius: 12px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.08);
}
.card h2 {
    margin-bottom: 10px;
    color: #b4b3c6;
}

ul {
    padding-left: 20px;
}
footer {
    text-align: center;
    margin-top: 20px;
    background: #0eb8de;
    color: white;
    padding: 10px;
    border-radius: 10px;
    font-size: 10px;
}
